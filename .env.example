# Copy to .env for local runs (NEVER commit .env). In GitHub, set these as
# repository secrets instead (Settings > Secrets and variables > Actions).

ANTHROPIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=soundcave-gtm-agent/0.1 by u/your_reddit_username
# Google Sheets sink (Sheets IS the state), driven via an Apps Script web app --
# no Google Cloud / service account needed. Deploy scripts/apps_script/Code.gs
# from the sheet (Extensions > Apps Script) as a Web app, then paste its /exec URL:
SHEETS_WEBHOOK_URL=
# Optional shared secret: set the same value as the script's TOKEN property.
SHEETS_WEBHOOK_TOKEN=
