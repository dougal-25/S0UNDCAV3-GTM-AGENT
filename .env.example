# Copy to .env for local runs (NEVER commit .env). In GitHub, set these as
# repository secrets instead (Settings > Secrets and variables > Actions).

ANTHROPIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=soundcave-gtm-agent/0.1 by u/your_reddit_username
# Google Sheets sink (Sheets IS the state). Create a Google Cloud service
# account with the Sheets API enabled, and share your leads sheet with the
# service account's client_email as an Editor.
# Paste the FULL service-account JSON key on a single line:
GOOGLE_SERVICE_ACCOUNT_JSON=
# The sheet key from its URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=
